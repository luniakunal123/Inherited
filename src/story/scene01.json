{"inkVersion":21,"root":[[{"->":"act1_screen1"},["done",{"#n":"g-0"}],null],"done",{"act1_screen1":["#","^character:none","/#","#","^image:Act1","/#","^The results are out.","\n","^[BREAK]","\n",{"->":"act1_screen2"},null],"act1_screen2":["#","^character:rahul_teen_neutral","/#","#","^image:Act1","/#","ev",{"VAR?":"player_name"},"out","/ev","^, you are 16.","\n","^Your phone is face-down on the desk.","\n","^You put it there twenty minutes ago and haven't touched it since.","\n","^Everyone around you already knows.","\n","^[BREAK]","\n",{"->":"act1_choice"},null],"act1_choice":[["#","^character:rahul_teen_tense","/#","#","^image:Act2","/#","^Rohan got 91. He told you without being asked.","\n","^What do you do?","\n","ev","str","^Turn it over and look","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Ask Rohan to check for you","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Put it in your bag. You'll look at home.","/str","/ev",{"*":".^.c-2","flg":20},"ev","str","^LOCKED: Call home. Tell them before you see it yourself.","/str","/ev",{"*":".^.c-3","flg":20},{"c-0":["\n",{"->":"act1_choice_option1"},{"#f":5}],"c-1":["\n",{"->":"act1_choice_option2"},{"#f":5}],"c-2":["\n",{"->":"act1_choice_option3"},{"#f":5}],"c-3":["\n",{"->":".^.^.^"},{"#f":5}]}],null],"act1_choice_option1":["#","^character:rahul_teen_tense","/#","#","^image:Option1","/#","^57 out of 100.","\n","^You read it three times.","\n","^[BREAK]","\n",{"->":"act1_end"},null],"act1_choice_option2":["#","^character:rahul_teen_tense","/#","#","^image:Option2","/#","^Rohan reads it for you.","\n","^57 out of 100.","\n","^He says the number with a kind face.","\n","^That somehow makes it worse.","\n","^[BREAK]","\n",{"->":"act1_end"},null],"act1_choice_option3":["#","^character:rahul_teen_tense","/#","#","^image:Option3","/#","^It will still be the same number at home.","\n","^You know this.","\n","^You put the phone in your bag anyway.","\n","^[BREAK]","\n",{"->":"act1_end"},null],"act1_end":["#","^character:none","/#","#","^background:black","/#",{"->":"act1_to_act2"},null],"act1_to_act2":["#","^character:none","/#","#","^background:fade_grey","/#","^[BREAK]","\n",{"->":"act2_screen1"},null],"act2_screen1":["#","^character:rahul_child_neutral","/#","#","^background:home_entrance_evening","/#","^The floor is cold under your feet.","\n","^That's the first thing.","\n","^You are sitting outside the kitchen because Mummy said wait there,","\n","^and you are waiting,","\n","^and through the door you can hear the phone being put down.","\n","^Papa is home early.","\n","^He is never home early.","\n","^[BREAK]","\n",{"->":"act2_screen2"},null],"act2_screen2":["#","^character:rahul_child_neutral","/#","#","^background:home_entrance_evening","/#","^You are eight years old.","\n","^Your class test came back today.","\n","^64 out of 100.","\n","^You don't know yet that this number will live in this house for the next three weeks.","\n","^You only know that it is in your bag and your bag is in the other room and Papa's chappals are at the door.","\n","^[BREAK]","\n",{"->":"act2_choice1"},null],"act2_choice1":[["#","^character:rahul_child_tense","/#","#","^background:home_entrance_evening","/#","^Mummy comes out of the kitchen.","\n","^She sees your face.","\n","^She already knows something happened at school —","\n","^teachers have a way of calling before the children get home.","\n","^She doesn't say anything yet.","\n","^She just looks at you.","\n","ev","str","^Tell her before Papa sees","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Ask her what Papa already knows","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Say nothing. Wait.","/str","/ev",{"*":".^.c-2","flg":20},"ev","str","^PERMANENT: Ask her to sit with you when you tell him.","/str","/ev",{"*":".^.c-3","flg":20},{"c-0":["\n","ev",{"VAR?":"stress"},10,"+","/ev",{"VAR=":"stress","re":true},"^You say the number out loud.","\n","^It sounds smaller when you say it.","\n",{"->":"act2_papa_calls"},{"#f":5}],"c-1":["\n","ev",{"VAR?":"stress"},15,"+","/ev",{"VAR=":"stress","re":true},"^She looks at the kitchen door.","\n","^That's her answer.","\n",{"->":"act2_papa_calls"},{"#f":5}],"c-2":["\n","ev",{"VAR?":"stress"},20,"+","/ev",{"VAR=":"stress","re":true},"^The waiting is its own answer.","\n",{"->":"act2_papa_calls"},{"#f":5}],"c-3":["\n",{"->":".^.^.^"},{"#f":5}]}],null],"act2_papa_calls":["#","^character:rahul_child_tense","/#","#","^background:home_entrance_evening","/#","^Papa's voice comes from the other room.","\n","^\"","ev",{"VAR?":"player_name"},"out","/ev","^.\"","\n","^Just your name. Nothing else.","\n","^You have learned to read everything in the way he says it.","\n","^Tonight it means: I already know.","\n","^Tonight it means: come here.","\n","^[BREAK]","\n",{"->":"act2_living_room"},null],"act2_living_room":["#","^character:rahul_child_fear","/#","#","^background:living_room_night","/#","^The living room feels smaller at night.","\n","^Papa is in his chair.","\n","^He hasn't changed out of his office clothes yet.","\n","^That means he came straight to this.","\n","^The test paper is on the arm of the chair.","\n","^You don't know how it got there.","\n","^Your bag was in the other room.","\n","^He doesn't look angry.","\n","^That's the thing nobody tells you —","\n","^it's worse when they don't look angry.","\n","^He just looks tired.","\n","^And like you made him that way.","\n","^[BREAK]","\n",{"->":"act2_choice2"},null],"act2_choice2":[["#","^character:rahul_child_fear","/#","#","^background:living_room_night","/#","^He picks up the paper.","\n","^He holds it the way you'd hold something you found in the drain.","\n","^64.","\n","^He says the number once.","\n","^Then: \"Rohan's father called me today.\"","\n","^At the office.","\n","^\"He wanted to know if everything was okay at home.\"","\n","ev","str","^\"I'll do better next time.\"","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^\"The paper was hard. Everyone did badly.\"","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Say nothing. Look at the floor.","/str","/ev",{"*":".^.c-2","flg":20},"ev","str","^PERMANENT: \"I didn't understand the chapter. I was scared to ask.\"","/str","/ev",{"*":".^.c-3","flg":20},{"c-0":["\n","ev",{"VAR?":"stress"},10,"+","/ev",{"VAR=":"stress","re":true},"^He repeats it back, flat. \"Better.\"","\n",{"->":"act2_slap"},{"#f":5}],"c-1":["\n","ev",{"VAR?":"stress"},20,"+","/ev",{"VAR=":"stress","re":true},"^He looks at you the way you look at a sum that doesn't add up.","\n",{"->":"act2_slap"},{"#f":5}],"c-2":["\n","ev",{"VAR?":"stress"},15,"+","/ev",{"VAR=":"stress","re":true},"^The floor has a crack in it you've never noticed before.","\n","^You study it.","\n",{"->":"act2_slap"},{"#f":5}],"c-3":["\n",{"->":".^.^.^"},{"#f":5}]}],null],"act2_slap":["#","^character:rahul_child_fear","/#","#","^background:living_room_night","/#","^\"What do I tell people.\"","\n","^He doesn't say it like a question.","\n","^A pause that is one beat too long.","\n","^[BREAK]","\n",{"->":"act2_slap2"},null],"act2_slap2":["^It's fast.","\n","^You don't see his hand.","\n","^You only feel the heat on your cheek","\n","^and then the room is very loud","\n","^and then very quiet","\n","^and Mummy is in the kitchen doorway","\n","^and she doesn't move","\n","^and you learn something in that second","\n","^that you will carry for eight years","\n","^without ever putting a name to it.","\n","^[BREAK]","\n",{"->":"act2_geometry_box"},null],"act2_geometry_box":["#","^character:rahul_child_neutral","/#","#","^background:bedroom_day","/#","^Three days later.","\n","^Papa comes home and puts something on your desk.","\n","^He doesn't say anything.","\n","^He doesn't meet your eye.","\n","^He goes to wash his hands.","\n","^It's a geometry box.","\n","^The good kind. German compass.","\n","^The one you pointed at in the shop three months ago","\n","^and he said not now.","\n","^You sit there for a long time.","\n","^You are eight years old","\n","^and you already understand","\n","^that this is the only language he has for sorry.","\n","^That it isn't quite sorry.","\n","^That you will take it anyway.","\n","^Because it is what there is.","\n","^[BREAK]","\n",{"->":"act3_screen1"},null],"act3_screen1":["#","^character:none","/#","#","^background:fade_white","/#","^You are not ","ev",{"VAR?":"player_name"},"out","/ev","^ anymore.","\n","^[BREAK]","\n",{"->":"act3_screen2"},null],"act3_screen2":["#","^character:papa_tired","/#","#","^background:living_room_night","/#","^You are Papa.","\n","^You are 44 years old.","\n","^You have been tired for eleven years.","\n","^You came home early today because your father called.","\n","^At the office.","\n","^He wanted to know how the boy was doing in school.","\n","^He said: \"Our name means something in this town.\"","\n","^He said it the way he always says things.","\n","^Like a door closing.","\n","^[BREAK]","\n",{"->":"act3_depletion1"},null],"act3_depletion1":["#","^character:papa_tired","/#","#","^background:office_corridor","/#","^Before you left the office —","\n","^your supervisor stopped you in the corridor.","\n","^The quarterly numbers are short.","\n","^He didn't say anything directly.","\n","^He didn't have to.","\n","ev",{"VAR?":"composure"},20,"-","/ev",{"VAR=":"composure","re":true},"ev",{"VAR?":"energy"},15,"-","/ev",{"VAR=":"energy","re":true},"^[BREAK]","\n",{"->":"act3_depletion2"},null],"act3_depletion2":["#","^character:papa_tired","/#","#","^background:home_entrance_evening","/#","^Before you came home —","\n","^the landlord's message was on your phone.","\n","^Deposit increase. From next month.","\n","^You read it in the auto.","\n","^You didn't reply.","\n","ev",{"VAR?":"composure"},15,"-","/ev",{"VAR=":"composure","re":true},"ev",{"VAR?":"stress"},20,"+","/ev",{"VAR=":"stress","re":true},"^[BREAK]","\n",{"->":"act3_depletion3"},null],"act3_depletion3":["#","^character:papa_tired","/#","#","^background:home_entrance_evening","/#","^Your wife says the school fee is due Thursday.","\n","^She says it quietly, knowing the timing.","\n","^You nod.","\n","^You don't know yet where it's coming from.","\n","ev",{"VAR?":"composure"},15,"-","/ev",{"VAR=":"composure","re":true},"ev",{"VAR?":"stress"},15,"+","/ev",{"VAR=":"stress","re":true},"^[BREAK]","\n",{"->":"act3_flip_choice"},null],"act3_flip_choice":[["#","^character:papa_controlled","/#","#","^background:living_room_night","/#","^64.","\n","^You say the number.","\n","^Then you hear yourself say:","\n","^\"Rohan's father called me today.\"","\n","^You hear it like it's coming from another room.","\n","^Like your mouth learned this from somewhere","\n","^and is running the script","\n","^while you watch from slightly behind your own eyes.","\n","ev","str","^\"Rohan's father called me. At the office.\"","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^\"I'm not angry. I'm disappointed.\"","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Set the paper down. Say nothing tonight.","/str","/ev",{"*":".^.c-2","flg":20},"ev","str","^FAINT: \"Tell me what happened with this chapter.\"","/str","/ev",{"*":".^.c-3","flg":20},{"c-0":["\n","ev",false,"/ev",{"VAR=":"chose_kind_option","re":true},"^The script runs.","\n","^It does what it always does.","\n","^It works.","\n","^The pressure releases.","\n","^Your son's face does the thing you remember your face doing.","\n","^You recognise it and look away.","\n",{"->":"act3_end"},{"#f":5}],"c-1":["\n","ev",false,"/ev",{"VAR=":"chose_kind_option","re":true},"^Different words.","\n","^The door closes the same way.","\n",{"->":"act3_end"},{"#f":5}],"c-2":["\n","ev",false,"/ev",{"VAR=":"chose_kind_option","re":true},"^You eat dinner.","\n","^The number sits between you all evening","\n","^like a third person at the table.","\n",{"->":"act3_end"},{"#f":5}],"c-3":["\n","ev",true,"/ev",{"VAR=":"chose_kind_option","re":true},"ev",true,"/ev",{"VAR=":"can_call_home","re":true},"^The words come out wrong.","\n","^You don't have the shape for this conversation.","\n","^Nobody ever had it with you.","\n","^You sit there, both of you,","\n","^in the clumsy silence","\n","^of a thing being tried for the first time.","\n","^It isn't a good conversation.","\n","^But it's a different one.","\n",{"->":"act3_end"},{"#f":5}]}],null],"act3_end":["#","^character:none","/#","#","^background:fade_grey","/#","^[BREAK]","\n",{"->":"act4_return"},null],"act4_return":["#","^character:rahul_teen_neutral","/#","#","^background:classroom_day","/#","^Your phone is face-down on the desk.","\n","^It has been there for twenty-three minutes.","\n","^[BREAK]","\n",{"->":"act4_choice"},null],"act4_choice":[["#","^character:rahul_teen_neutral","/#","#","^background:classroom_day","/#","^What do you do?","\n","ev","str","^Turn it over and look","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Ask Rohan to check for you","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Put it in your bag. You'll look at home.","/str","/ev",{"*":".^.c-2","flg":20},"ev","str","^LOCKED: Call home. Tell them before you see it yourself.","/str","/ev",{"*":".^.c-3","flg":20},{"c-0":["\n","^You look at the number.","\n","^You put the phone back down.","\n",{"->":"act4_ending"},{"#f":5}],"c-1":["\n","^Rohan checks.","\n","^You nod.","\n",{"->":"act4_ending"},{"#f":5}],"c-2":["\n","^The bag goes on your shoulder.","\n",{"->":"act4_ending"},{"#f":5}],"c-3":["\n",{"->":"act4_call_home"},{"#f":5}]}],null],"act4_call_home":["#","^character:rahul_teen_neutral","/#","#","^background:classroom_day","/#","^The phone rings twice.","\n","^Then your mother picks up.","\n","^You say the number before she asks.","\n","^There is a silence on the other end.","\n","^Then: \"Okay. Come home.\"","\n","^Two words.","\n","^You don't know yet what to do with them.","\n","^[BREAK]","\n",{"->":"act4_ending"},null],"act4_ending":["#","^character:none","/#","#","^background:black","/#","^You are sixteen.","\n","^You were eight.","\n","^You will be both for the rest of your life.","\n","end",